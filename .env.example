# ClickUp
# Get your API token at: https://app.clickup.com/settings/apps
CLICKUP_API_TOKEN=pk_your_token_here
CLICKUP_TEAM_ID=your_team_id
CLICKUP_USER_ID=your_user_id
CLICKUP_HIGHLEVEL_LIST_ID=your_highlevel_list_id
CLICKUP_RELEASES_LIST_ID=your_releases_list_id

# Slack
# You need a Slack User Token (xoxp-...) with scopes: reminders:read
# Create at: https://api.slack.com/apps
SLACK_USER_TOKEN=xoxp-your-token-here
SLACK_XOXC_TOKEN=xoxc-your-token-here
SLACK_D_COOKIE=xoxd-your-cookie-here

# Google (Gmail + Calendar)
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
# Enable Gmail API and Calendar API
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token
FLAT2VR_CALENDAR_ID=your_calendar_id
MILESTONES_CALENDAR_ID=your_milestones_calendar_id

# User Identity (for Fireflies meeting filtering)
MY_EMAIL=your@email.com
MY_NAME=yourfirstname

# Fireflies
# Get your API key at: https://app.fireflies.ai/integrations/custom/fireflies
FIREFLIES_API_KEY=your_api_key_here
